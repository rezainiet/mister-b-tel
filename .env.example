# =============================================================================
# Mister B — local development environment template
# Copy this file to `.env` and fill in values you actually need.
# =============================================================================

# Runtime
NODE_ENV=development
PORT=3000

# Database (MySQL 8). Leave empty to run without persistence — DB-backed
# features (dashboard charts, tracking, telegram tables) will then no-op.
# To enable persistence locally with Docker:
#   docker run --name misterb-mysql -e MYSQL_ROOT_PASSWORD=rootpass \
#     -e MYSQL_DATABASE=misterb -p 3306:3306 -d mysql:8
DATABASE_URL=mysql://root:rootpass@127.0.0.1:3306/misterb

# Cookie / JWT signing — change in production.
JWT_SECRET=local-dev-jwt-secret-change-me

# Local-only dashboard password. Production must override.
DASHBOARD_PASSWORD=1234

# Telegram (optional locally — workers no-op without these)
TELEGRAM_BOT_USERNAME=Misternb_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_GROUP_URL=https://t.me/+sdIa7KNoIbNjMTg0
# Comma-separated bare usernames (no @) authorized to run /rapport and to
# receive scheduled admin reports. Falls back to bestmanylitics,coucoulala123.
TELEGRAM_ADMIN_USERNAMES=

# Meta / Facebook Conversions API (optional)
META_PIXEL_ID=
# Mirror of META_PIXEL_ID for the browser pixel snippet (must match).
VITE_META_PIXEL_ID=
META_CONVERSIONS_TOKEN=

# Manus-hosted OAuth portal (leave blank locally — login UI is disabled)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Frontend analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Manus Forge proxy (optional, frontend + backend)
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
